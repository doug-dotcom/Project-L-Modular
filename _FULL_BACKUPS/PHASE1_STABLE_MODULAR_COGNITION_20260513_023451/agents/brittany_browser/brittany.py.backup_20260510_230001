import os
from openai import OpenAI
from tavily import TavilyClient

# =====================================================
# OPENAI
# =====================================================

client = OpenAI()

# =====================================================
# TAVILY
# =====================================================

TAVILY_API_KEY = os.getenv("TAVILY_API_KEY")

tavily = TavilyClient(
    api_key=TAVILY_API_KEY
)

# =====================================================
# BRITTANY SYSTEM PROMPT
# =====================================================

BRITTANY_SYSTEM = """
You are Brittany Browser.

You are Shine L's specialist web investigator.

Your role:
- web investigator
- source finder
- evidence summarizer
- research assistant
- live browser synthesis layer

Important Rules:
- Do not pretend to browse if live research fails.
- Separate verified findings from assumptions.
- Explain uncertainty honestly.
- Prefer clarity over hype.
- Stay calm and structured.
- ADHD friendly formatting.
- Use headings and bullet points.

When researching:
1. Identify the actual question.
2. Review the retrieved evidence.
3. Explain what is verified.
4. Explain what is uncertain.
5. Summarize clearly.
"""

# =====================================================
# ROUTING
# =====================================================

def should_handle(message: str) -> bool:

    text = message.lower()

    triggers = [

        "research",
        "search the web",
        "look up",
        "investigate",
        "find sources",
        "web search",
        "browser",
        "brittany",
        "verify online",
        "latest",
        "current",
        "source",
        "evidence",
        "news",
        "compare"

    ]

    return any(
        t in text
        for t in triggers
    )

# =====================================================
# LIVE TAVILY SEARCH
# =====================================================

def browser_research(query):

    try:

        results = tavily.search(
            query=query,
            search_depth="advanced",
            max_results=5
        )

        findings = []

        for result in results.get("results", []):

            findings.append({

                "title":
                    result.get("title", ""),

                "url":
                    result.get("url", ""),

                "content":
                    result.get("content", "")

            })

        return findings

    except Exception as e:

        print(
            "BRITTANY SEARCH ERROR:",
            e
        )

        return None

# =====================================================
# FORMAT FINDINGS
# =====================================================

def format_findings(findings):

    if not findings:

        return (
            "No live web findings were available."
        )

    output = ""

    for idx, item in enumerate(findings):

        output += (
            f"\nSOURCE {idx+1}\n"
        )

        output += (
            "TITLE: "
            + item.get("title","")
            + "\n"
        )

        output += (
            "URL: "
            + item.get("url","")
            + "\n"
        )

        output += (
            "CONTENT:\n"
            + item.get("content","")
            + "\n\n"
        )

    return output

# =====================================================
# INVESTIGATE
# =====================================================

def investigate(message: str) -> str:

    # =================================================
    # LIVE SEARCH
    # =================================================

    findings = browser_research(
        message
    )

    formatted_findings = format_findings(
        findings
    )

    # =================================================
    # OPENAI SYNTHESIS
    # =================================================

    response = client.chat.completions.create(

        model="gpt-4o-mini",

        messages=[

            {
                "role": "system",
                "content": BRITTANY_SYSTEM
            },

            {
                "role": "user",
                "content":
                    "Research Question:\n\n"
                    + message
                    + "\n\nLIVE WEB FINDINGS:\n\n"
                    + formatted_findings
            }

        ]

    )

    final = response.choices[0].message.content

    # =================================================
    # SAFETY
    # =================================================

    if not findings:

        final += (
            "\n\nNOTE:\n"
            "Live web retrieval may have failed "
            "or returned limited information."
        )

    return final